<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_BusinessTrip"
                  targetNamespace="http://bizagi.com/bpmn/Test30/BusinessTrip">
  <bpmn:collaboration id="Collaboration_BusinessTrip">
    <bpmn:participant id="Participant_BusinessTrip" name="درخواست ماموریت" processRef="Process_BusinessTrip" />
  </bpmn:collaboration>
  <bpmn:process id="Process_BusinessTrip" name="درخواست ماموریت" isExecutable="true">
    <bpmn:laneSet id="LaneSet_BusinessTrip">
      <bpmn:lane id="Lane_Employee" name="کارمند (متقاضی)">
        <bpmn:flowNodeRef>StartMission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubmitMission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubmitReport</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="مدیر مستقیم">
        <bpmn:flowNodeRef>ManagerApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ManagerDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HSE" name="واحد HSE (ایمنی)">
        <bpmn:flowNodeRef>Gateway_FieldMission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>HSEReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FieldMerge</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin" name="امور اداری">
        <bpmn:flowNodeRef>Gateway_TransportType</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdminArrangement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TransportMerge</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TicketOfficer" name="مسئول تهیه بلیط">
        <bpmn:flowNodeRef>BookTicket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CancelBooking</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyTicketOfficer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Finance" name="امور مالی">
        <bpmn:flowNodeRef>Gateway_Advance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>FinanceAdvance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdvanceMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>FinanceSettlement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndApproved</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartMission" name="شروع">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="SubmitMission" name="ثبت درخواست ماموریت">
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_ToManager</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="ManagerApproval" name="تایید مدیر مستقیم">
      <bpmn:incoming>Flow_ToManager</bpmn:incoming>
      <bpmn:outgoing>Flow_ToManagerGw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ManagerDecision" name="تایید شد؟" default="Flow_MgrApprove">
      <bpmn:incoming>Flow_ToManagerGw</bpmn:incoming>
      <bpmn:outgoing>Flow_MgrReject</bpmn:outgoing>
      <bpmn:outgoing>Flow_MgrApprove</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndRejected" name="رد شد">
      <bpmn:incoming>Flow_MgrReject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_FieldMission" name="ماموریت سایت/معدن؟" default="Flow_FieldNo">
      <bpmn:incoming>Flow_MgrApprove</bpmn:incoming>
      <bpmn:outgoing>Flow_FieldYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_FieldNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="HSEReview" name="بررسی ایمنی و HSE">
      <bpmn:incoming>Flow_FieldYes</bpmn:incoming>
      <bpmn:outgoing>Flow_HseToMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_FieldMerge">
      <bpmn:incoming>Flow_HseToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_FieldNo</bpmn:incoming>
      <bpmn:outgoing>Flow_ToAdvanceGw</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_Advance" name="پیش‌پرداخت دارد؟" default="Flow_AdvanceNo">
      <bpmn:incoming>Flow_ToAdvanceGw</bpmn:incoming>
      <bpmn:outgoing>Flow_AdvanceYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_AdvanceNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="FinanceAdvance" name="بررسی و پرداخت پیش‌پرداخت">
      <bpmn:incoming>Flow_AdvanceYes</bpmn:incoming>
      <bpmn:outgoing>Flow_AdvanceToMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_AdvanceMerge">
      <bpmn:incoming>Flow_AdvanceToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_AdvanceNo</bpmn:incoming>
      <bpmn:outgoing>Flow_ToTransportGw</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_TransportType" name="نوع تأمین نقلیه؟" default="Flow_TransportOrg">
      <bpmn:incoming>Flow_ToTransportGw</bpmn:incoming>
      <bpmn:outgoing>Flow_TransportPublic</bpmn:outgoing>
      <bpmn:outgoing>Flow_TransportOrg</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="AdminArrangement" name="هماهنگی خودرو سازمانی و اقامت">
      <bpmn:incoming>Flow_TransportOrg</bpmn:incoming>
      <bpmn:outgoing>Flow_AdminToMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="BookTicket" name="تهیه بلیط">
      <bpmn:incoming>Flow_TransportPublic</bpmn:incoming>
      <bpmn:outgoing>Flow_TicketToMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="CancelBooking" name="لغو ماموریت" attachedToRef="BookTicket" cancelActivity="true">
      <bpmn:outgoing>Flow_CancelToNotify</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgCancelBooking" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="NotifyTicketOfficer" name="اطلاع لغو ماموریت به مسئول تهیه بلیط">
      <bpmn:incoming>Flow_CancelToNotify</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyToEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndCancelled" name="ماموریت لغو شد">
      <bpmn:incoming>Flow_NotifyToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_TransportMerge">
      <bpmn:incoming>Flow_AdminToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_TicketToMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_ToReport</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="SubmitReport" name="ثبت گزارش و درخواست تسویه">
      <bpmn:incoming>Flow_ToReport</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSettlement</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="FinanceSettlement" name="تسویه حساب مالی">
      <bpmn:incoming>Flow_ToSettlement</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndApproved" name="پایان (انجام و تسویه شد)">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start" sourceRef="StartMission" targetRef="SubmitMission" />
    <bpmn:sequenceFlow id="Flow_ToManager" sourceRef="SubmitMission" targetRef="ManagerApproval" />
    <bpmn:sequenceFlow id="Flow_ToManagerGw" sourceRef="ManagerApproval" targetRef="Gateway_ManagerDecision" />
    <bpmn:sequenceFlow id="Flow_MgrReject" name="رد" sourceRef="Gateway_ManagerDecision" targetRef="EndRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">BusinessTrip.managerApproved = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_MgrApprove" name="تایید" sourceRef="Gateway_ManagerDecision" targetRef="Gateway_FieldMission" />
    <bpmn:sequenceFlow id="Flow_FieldYes" name="بله" sourceRef="Gateway_FieldMission" targetRef="HSEReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">BusinessTrip.isSiteMission = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_FieldNo" name="خیر" sourceRef="Gateway_FieldMission" targetRef="Gateway_FieldMerge" />
    <bpmn:sequenceFlow id="Flow_HseToMerge" sourceRef="HSEReview" targetRef="Gateway_FieldMerge" />
    <bpmn:sequenceFlow id="Flow_ToAdvanceGw" sourceRef="Gateway_FieldMerge" targetRef="Gateway_Advance" />
    <bpmn:sequenceFlow id="Flow_AdvanceYes" name="بله" sourceRef="Gateway_Advance" targetRef="FinanceAdvance">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">BusinessTrip.advanceRequested = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AdvanceNo" name="خیر" sourceRef="Gateway_Advance" targetRef="Gateway_AdvanceMerge" />
    <bpmn:sequenceFlow id="Flow_AdvanceToMerge" sourceRef="FinanceAdvance" targetRef="Gateway_AdvanceMerge" />
    <bpmn:sequenceFlow id="Flow_ToTransportGw" sourceRef="Gateway_AdvanceMerge" targetRef="Gateway_TransportType" />
    <bpmn:sequenceFlow id="Flow_TransportPublic" name="عمومی" sourceRef="Gateway_TransportType" targetRef="BookTicket">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">BusinessTrip.isPublicTransport = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_TransportOrg" name="سازمانی" sourceRef="Gateway_TransportType" targetRef="AdminArrangement" />
    <bpmn:sequenceFlow id="Flow_AdminToMerge" sourceRef="AdminArrangement" targetRef="Gateway_TransportMerge" />
    <bpmn:sequenceFlow id="Flow_TicketToMerge" sourceRef="BookTicket" targetRef="Gateway_TransportMerge" />
    <bpmn:sequenceFlow id="Flow_CancelToNotify" sourceRef="CancelBooking" targetRef="NotifyTicketOfficer" />
    <bpmn:sequenceFlow id="Flow_NotifyToEnd" sourceRef="NotifyTicketOfficer" targetRef="EndCancelled" />
    <bpmn:sequenceFlow id="Flow_ToReport" sourceRef="Gateway_TransportMerge" targetRef="SubmitReport" />
    <bpmn:sequenceFlow id="Flow_ToSettlement" sourceRef="SubmitReport" targetRef="FinanceSettlement" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="FinanceSettlement" targetRef="EndApproved" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_BusinessTrip">
    <bpmndi:BPMNPlane id="BPMNPlane_BusinessTrip" bpmnElement="Collaboration_BusinessTrip">
      <bpmndi:BPMNShape id="Participant_BusinessTrip_di" bpmnElement="Participant_BusinessTrip" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="1850" height="900" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Employee_di" bpmnElement="Lane_Employee" isHorizontal="true">
        <dc:Bounds x="150" y="80" width="1820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="150" y="230" width="1820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HSE_di" bpmnElement="Lane_HSE" isHorizontal="true">
        <dc:Bounds x="150" y="380" width="1820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admin_di" bpmnElement="Lane_Admin" isHorizontal="true">
        <dc:Bounds x="150" y="530" width="1820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TicketOfficer_di" bpmnElement="Lane_TicketOfficer" isHorizontal="true">
        <dc:Bounds x="150" y="680" width="1820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Finance_di" bpmnElement="Lane_Finance" isHorizontal="true">
        <dc:Bounds x="150" y="830" width="1820" height="150" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartMission_di" bpmnElement="StartMission">
        <dc:Bounds x="192" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="180" width="24" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubmitMission_di" bpmnElement="SubmitMission">
        <dc:Bounds x="260" y="115" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ManagerApproval_di" bpmnElement="ManagerApproval">
        <dc:Bounds x="400" y="265" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ManagerDecision_di" bpmnElement="Gateway_ManagerDecision" isMarkerVisible="true">
        <dc:Bounds x="550" y="280" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="542" y="337" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndRejected_di" bpmnElement="EndRejected">
        <dc:Bounds x="650" y="287" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="647" y="330" width="42" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FieldMission_di" bpmnElement="Gateway_FieldMission" isMarkerVisible="true">
        <dc:Bounds x="625" y="430" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="605" y="487" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="HSEReview_di" bpmnElement="HSEReview">
        <dc:Bounds x="730" y="415" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FieldMerge_di" bpmnElement="Gateway_FieldMerge" isMarkerVisible="true">
        <dc:Bounds x="880" y="430" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Advance_di" bpmnElement="Gateway_Advance" isMarkerVisible="true">
        <dc:Bounds x="960" y="880" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="948" y="937" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FinanceAdvance_di" bpmnElement="FinanceAdvance">
        <dc:Bounds x="1050" y="865" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdvanceMerge_di" bpmnElement="Gateway_AdvanceMerge" isMarkerVisible="true">
        <dc:Bounds x="1200" y="880" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_TransportType_di" bpmnElement="Gateway_TransportType" isMarkerVisible="true">
        <dc:Bounds x="1290" y="580" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1276" y="555" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdminArrangement_di" bpmnElement="AdminArrangement">
        <dc:Bounds x="1390" y="565" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BookTicket_di" bpmnElement="BookTicket">
        <dc:Bounds x="1390" y="715" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CancelBooking_di" bpmnElement="CancelBooking">
        <dc:Bounds x="1422" y="777" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1460" y="813" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="NotifyTicketOfficer_di" bpmnElement="NotifyTicketOfficer">
        <dc:Bounds x="1560" y="715" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndCancelled_di" bpmnElement="EndCancelled">
        <dc:Bounds x="1710" y="737" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1696" y="780" width="64" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_TransportMerge_di" bpmnElement="Gateway_TransportMerge" isMarkerVisible="true">
        <dc:Bounds x="1550" y="580" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubmitReport_di" bpmnElement="SubmitReport">
        <dc:Bounds x="1640" y="115" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FinanceSettlement_di" bpmnElement="FinanceSettlement">
        <dc:Bounds x="1780" y="865" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndApproved_di" bpmnElement="EndApproved">
        <dc:Bounds x="1920" y="887" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1898" y="930" width="82" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_di" bpmnElement="Flow_Start">
        <di:waypoint x="228" y="155" /><di:waypoint x="260" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToManager_di" bpmnElement="Flow_ToManager">
        <di:waypoint x="310" y="195" /><di:waypoint x="310" y="305" /><di:waypoint x="400" y="305" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToManagerGw_di" bpmnElement="Flow_ToManagerGw">
        <di:waypoint x="500" y="305" /><di:waypoint x="550" y="305" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MgrReject_di" bpmnElement="Flow_MgrReject">
        <di:waypoint x="600" y="305" /><di:waypoint x="650" y="305" />
        <bpmndi:BPMNLabel><dc:Bounds x="617" y="287" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MgrApprove_di" bpmnElement="Flow_MgrApprove">
        <di:waypoint x="575" y="330" /><di:waypoint x="575" y="455" /><di:waypoint x="625" y="455" />
        <bpmndi:BPMNLabel><dc:Bounds x="545" y="400" width="30" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FieldYes_di" bpmnElement="Flow_FieldYes">
        <di:waypoint x="675" y="455" /><di:waypoint x="730" y="455" />
        <bpmndi:BPMNLabel><dc:Bounds x="690" y="437" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FieldNo_di" bpmnElement="Flow_FieldNo">
        <di:waypoint x="650" y="480" /><di:waypoint x="650" y="510" /><di:waypoint x="905" y="510" /><di:waypoint x="905" y="480" />
        <bpmndi:BPMNLabel><dc:Bounds x="770" y="492" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HseToMerge_di" bpmnElement="Flow_HseToMerge">
        <di:waypoint x="830" y="455" /><di:waypoint x="880" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToAdvanceGw_di" bpmnElement="Flow_ToAdvanceGw">
        <di:waypoint x="905" y="480" /><di:waypoint x="905" y="905" /><di:waypoint x="960" y="905" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdvanceYes_di" bpmnElement="Flow_AdvanceYes">
        <di:waypoint x="1010" y="905" /><di:waypoint x="1050" y="905" />
        <bpmndi:BPMNLabel><dc:Bounds x="1020" y="887" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdvanceNo_di" bpmnElement="Flow_AdvanceNo">
        <di:waypoint x="985" y="930" /><di:waypoint x="985" y="960" /><di:waypoint x="1225" y="960" /><di:waypoint x="1225" y="930" />
        <bpmndi:BPMNLabel><dc:Bounds x="1095" y="942" width="20" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdvanceToMerge_di" bpmnElement="Flow_AdvanceToMerge">
        <di:waypoint x="1150" y="905" /><di:waypoint x="1200" y="905" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToTransportGw_di" bpmnElement="Flow_ToTransportGw">
        <di:waypoint x="1225" y="880" /><di:waypoint x="1225" y="605" /><di:waypoint x="1290" y="605" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TransportPublic_di" bpmnElement="Flow_TransportPublic">
        <di:waypoint x="1315" y="630" /><di:waypoint x="1315" y="755" /><di:waypoint x="1390" y="755" />
